# Google Gemini (server-side only — used from Next.js API routes)
GEMINI_API_KEY=

# MongoDB Atlas (Person 1 / push+cron)
MONGODB_URI=
MONGODB_DB=ezxpire

# Auth.js (Person 1)
AUTH_SECRET=

# Web Push (Person 4) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Protect Vercel Cron route
CRON_SECRET=
